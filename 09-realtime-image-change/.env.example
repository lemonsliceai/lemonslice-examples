# --- Shared (Next.js `/api/token` + LiveKit agent worker) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# LiveKit agent worker registration + dispatch target name (can be any value)
AGENT_NAME=lemonslice-image-change

# --- Agent only ---
# LemonSlice avatar API key
LEMONSLICE_API_KEY=
# Fal AI key for Nano Banana 2 Lite image edits (https://fal.ai)
FAL_KEY=
