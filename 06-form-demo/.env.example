# LiveKit (Cloud or self-hosted)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit Agents: worker registration + join token must use the same name (explicit dispatch).
# LIVEKIT_AGENT_NAME=form-demo

# LemonSlice avatar session (https://lemonslice.com/agents/api)
LEMONSLICE_API_KEY=

# Optional: override default demo portrait (368×560-ish face image URL)
AVATAR_IMAGE_URL=https://6ammc3n5zzf5ljnz.public.blob.vercel-storage.com/public/demo/sales.png

# Frontend (Next.js): only if the UI is served from a different origin than `/api/token`
# NEXT_PUBLIC_TOKEN_URL=https://your-app.example.com
